# ─── Kristy server config ───
PORT=3001

# Anthropic — Kristy runs entirely on Haiku
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# USDA FoodData Central — real macros for typed meal logging (free).
# Get a key: https://fdc.nal.usda.gov/api-key-signup.html
# If unset, typed meals gracefully fall back to Claude macro estimates.
USDA_API_KEY=

# Supabase — server uses the SERVICE ROLE key (trusted, bypasses RLS).
# Never expose the service role key to the frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated origins allowed to call the API (the Vite dev server, your prod domain)
CLIENT_ORIGIN=http://localhost:5173

# Optional — guards the all-users weekly summary cron run (POST /api/weekly-summary
# with an x-cron-secret header). Leave blank to disable the all-users trigger.
CRON_SECRET=

# ─── Stripe (web billing) ───
# The FIRST payment provider. In the Stripe dashboard create ONE product
# ("Kristy Membership") with TWO recurring prices, then paste their price ids
# (they look like price_xxx) into the two _PRICE_ vars below:
#   • Monthly — $7.99 USD, recurring monthly   → STRIPE_PRICE_MONTHLY
#   • Annual  — $59.99 USD, recurring yearly    → STRIPE_PRICE_ANNUAL
# Display prices live in client/src/lib/pricing.js — keep them in sync with these.
# Enable Stripe Tax to add tax on top at checkout — don't bake tax into the price.
# The webhook secret comes from the endpoint you create for /api/stripe/webhook.
# Leave all four blank to run without billing (trial + free features still work;
# the billing endpoints return a clean 503, and checkout logs which var is unset).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
