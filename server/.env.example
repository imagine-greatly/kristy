# ─── Kristy server config ───
PORT=3001

# Anthropic — Kristy runs entirely on Haiku
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# USDA FoodData Central — real macros for typed meal logging (free).
# Get a key: https://fdc.nal.usda.gov/api-key-signup.html
# If unset, typed meals gracefully fall back to Claude macro estimates.
USDA_API_KEY=

# Supabase — server uses the SERVICE ROLE key (trusted, bypasses RLS).
# Never expose the service role key to the frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated origins allowed to call the API (the Vite dev server, your prod domain)
CLIENT_ORIGIN=http://localhost:5173

# Optional — guards the all-users weekly summary cron run (POST /api/weekly-summary
# with an x-cron-secret header). Leave blank to disable the all-users trigger.
CRON_SECRET=
