# Copy to .env for local dev (`npx expo start`). In EAS builds these are supplied
# as EAS environment variables / secrets of the same names (see README).
#
# Same Supabase project + same Railway API as the web client — mobile is a pure
# client of the existing backend.

# Railway server base URL (no trailing slash). For a device on the same LAN in
# dev, use your machine's LAN IP, e.g. http://192.168.1.20:3001
EXPO_PUBLIC_API_URL=https://your-kristy-api.up.railway.app

# Supabase — identical to the web client's VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat public API key for the "Apple App Store" app (Project → API keys).
# Starts with "appl_". NOT a secret key.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx

# RevenueCat identifiers — must match the dashboard exactly. All optional: the
# defaults (below) match a conventional setup, so leave them blank if you use
# the standard names.
#   ENTITLEMENT  the entitlement that unlocks premium         (default: premium)
#   OFFERING     which offering to show; blank = the "current" one in the dashboard
#   *_PACKAGE    package identifiers inside the offering       (defaults: $rc_annual / $rc_monthly)
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=premium
EXPO_PUBLIC_REVENUECAT_OFFERING=
EXPO_PUBLIC_REVENUECAT_ANNUAL_PACKAGE=$rc_annual
EXPO_PUBLIC_REVENUECAT_MONTHLY_PACKAGE=$rc_monthly
