# ─── Kristy client config (Vite — only VITE_* vars reach the browser) ───

# Supabase project — anon/public key only (safe for the browser; RLS protects data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Where the Express API lives. Leave blank in dev to use the Vite proxy (/api).
VITE_API_URL=

# Set to "true" to explore the UI with mock AI responses and no Supabase/keys.
VITE_DEMO=false
